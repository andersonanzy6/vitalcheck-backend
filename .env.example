# API Key: https://aistudio.google.com/app/apikey
# Used for AI Health Assistant feature
GEMINI_API_KEY=your_gemini_api_key

# Available models (confirmed to support generateContent):
# - gemini-2.0-flash (stable, works with v1beta API) ✓ DEFAULT
# - gemini-2.5-flash (latest, may require v1 API)
# - gemini-2.0-flash-001 (older stable version)
# NOTE: Caching reduces API calls by ~70% for symptom checks
GEMINI_MODEL=gemini-2.0-flash

