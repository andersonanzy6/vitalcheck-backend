# ============================================
# VITALCHECK - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!
# ============================================

# ============ SERVER CONFIGURATION ============
PORT=5000
NODE_ENV=development|production

# ============ DATABASE ============
# MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Connection string: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/health_consult_db
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/health-consult

# ============ JWT AUTHENTICATION ============
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_EXPIRE=7d

